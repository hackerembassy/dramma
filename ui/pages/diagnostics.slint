import { Button, Palette, ListView } from "std-widgets.slint";

// level: 0 = neutral/grey · 1 = ok/green · 2 = warn/orange · 3 = error/red
export struct LogEntry {
    level: int,
    text: string,
}

export component Diagnostics inherits Rectangle {
    callback back-clicked();
    callback reset-bills();
    callback reenumerate-coins();
    callback play-sound();
    callback check-backend();

    in-out property <[LogEntry]> log-lines: [];
    in property <LogEntry> bill-status: { level: 0, text: "Initializing..." };
    in property <LogEntry> coin-status: { level: 0, text: "Initializing..." };
    in property <LogEntry> backend-status: { level: 0, text: "Not checked" };

    // Action buttons are locked for a brief moment after the page appears so
    // that the tap gesture that opened diagnostics cannot accidentally trigger them.
    property <bool> guard: true;
    Timer {
        interval: 500ms;
        running: root.guard;
        triggered => { root.guard = false; }
    }

    // Navigate back after 2 minutes of inactivity.  The component is
    // destroyed when navigating away, so the timer resets on each entry.
    property <int> seconds-left: 120;
    inactivity-timer := Timer {
        interval: 120s;
        running: true;
        triggered => { root.back-clicked(); }
    }
    Timer {
        interval: 1s;
        running: true;
        triggered => { if root.seconds-left > 0 { root.seconds-left -= 1; } }
    }

    // Background TouchArea — any tap resets the inactivity timer.
    // Placed before the content so foreground buttons still capture their own events.
    TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            inactivity-timer.running = false;
            inactivity-timer.running = true;
            root.seconds-left = 120;
        }
    }

    background: Palette.background;

    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // ── Header ────────────────────────────────────────────────────────
        HorizontalLayout {
            alignment: space-between;
            spacing: 16px;
            height: 56px;

            Button {
                text: "← Back (" + root.seconds-left + "s)";
                width: 130px;
                clicked => { root.back-clicked(); }
            }

            Text {
                text: "Diagnostics";
                font-size: 28px;
                font-weight: 700;
                color: Palette.foreground;
                vertical-alignment: center;
                horizontal-alignment: center;
                horizontal-stretch: 1;
            }

            // balance spacer so title stays centred
            Rectangle { width: 130px; }
        }

        // ── Action buttons ────────────────────────────────────────────────
        HorizontalLayout {
            spacing: 16px;
            alignment: center;
            height: 64px;

            Button {
                text: "Reset Bill Acceptor";
                width: 230px;
                enabled: !root.guard;
                clicked => {
                    inactivity-timer.running = false;
                    inactivity-timer.running = true;
                    root.seconds-left = 120;
                    root.reset-bills();
                }
            }

            Button {
                text: "Re-enumerate Coins";
                width: 230px;
                enabled: !root.guard;
                clicked => {
                    inactivity-timer.running = false;
                    inactivity-timer.running = true;
                    root.seconds-left = 120;
                    root.reenumerate-coins();
                }
            }

            Button {
                text: "Play Sound";
                width: 180px;
                enabled: !root.guard;
                clicked => {
                    inactivity-timer.running = false;
                    inactivity-timer.running = true;
                    root.seconds-left = 120;
                    root.play-sound();
                }
            }
        }

        // ── Status panel ─────────────────────────────────────────────────
        Rectangle {
            border-radius: 8px;
            border-width: 1px;
            border-color: Palette.color-scheme == ColorScheme.dark ? #444444 : #cccccc;
            background: Palette.color-scheme == ColorScheme.dark ? #1c1c1c : #f6f6f6;
            height: 118px;

            VerticalLayout {
                padding: 10px;
                spacing: 6px;

                // Bill acceptor row
                HorizontalLayout {
                    spacing: 8px;
                    height: 26px;
                    Text {
                        text: "Bill acceptor";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.55;
                        width: 130px;
                        vertical-alignment: center;
                    }
                    // status dot
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        y: (parent.height - self.height) / 2;
                        background: root.bill-status.level == 1 ? #4caf50 :
                                    root.bill-status.level == 2 ? #ff8c00 :
                                    root.bill-status.level == 3 ? #f44336 : #808080;
                    }
                    Text {
                        text: root.bill-status.text;
                        font-size: 13px;
                        color: Palette.foreground;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                }

                // Coin acceptor row
                HorizontalLayout {
                    spacing: 8px;
                    height: 26px;
                    Text {
                        text: "Coin acceptor";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.55;
                        width: 130px;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        y: (parent.height - self.height) / 2;
                        background: root.coin-status.level == 1 ? #4caf50 :
                                    root.coin-status.level == 2 ? #ff8c00 :
                                    root.coin-status.level == 3 ? #f44336 : #808080;
                    }
                    Text {
                        text: root.coin-status.text;
                        font-size: 13px;
                        color: Palette.foreground;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                }

                // Backend API row
                HorizontalLayout {
                    spacing: 8px;
                    height: 26px;
                    Text {
                        text: "Backend API";
                        font-size: 13px;
                        color: Palette.foreground;
                        opacity: 0.55;
                        width: 130px;
                        vertical-alignment: center;
                    }
                    Rectangle {
                        width: 10px;
                        height: 10px;
                        border-radius: 5px;
                        y: (parent.height - self.height) / 2;
                        background: root.backend-status.level == 1 ? #4caf50 :
                                    root.backend-status.level == 2 ? #ff8c00 :
                                    root.backend-status.level == 3 ? #f44336 : #808080;
                    }
                    Text {
                        text: root.backend-status.text;
                        font-size: 13px;
                        color: Palette.foreground;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                        overflow: elide;
                    }
                    Button {
                        text: "Check";
                        width: 80px;
                        height: 26px;
                        enabled: !root.guard;
                        clicked => {
                            inactivity-timer.running = false;
                            inactivity-timer.running = true;
                            root.seconds-left = 120;
                            root.check-backend();
                        }
                    }
                }
            }
        }

        // ── Log header ────────────────────────────────────────────────────
        Text {
            text: "Log  (newest first — " + root.log-lines.length + " lines):";
            font-size: 13px;
            color: Palette.foreground;
            opacity: 0.6;
            height: 20px;
        }

        // ── Scrollable log ────────────────────────────────────────────────
        log-view := ListView {
            vertical-stretch: 1;

            for entry[i] in root.log-lines: Rectangle {
                height: 22px;
                background: mod(i, 2) == 0
                    ? transparent
                    : Palette.color-scheme == ColorScheme.dark
                        ? #ffffff08
                        : #00000008;

                Text {
                    x: 6px;
                    width: parent.width - 12px;
                    height: parent.height;
                    text: entry.text;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                    color: entry.level == 3 ? #f44336 :
                           entry.level == 2 ? #ff8c00 :
                           Palette.foreground;
                }
            }
        }
    }
}
