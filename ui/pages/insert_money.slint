import { Button, Palette } from "std-widgets.slint";

export component InsertMoney inherits Rectangle {
    in-out property <int> current-amount: 0;
    in-out property <int> last-added-amount: 0;
    in property <string> username: "";
    in property <string> fundname: "";
    in property <int> seconds-left: 180;  // countdown updated by Rust

    callback cancel-clicked();
    callback done-clicked(string, int);  // username, amount
    callback screen-tapped();  // any tap on screen resets inactivity timer

    background: Palette.background;

    // Background TouchArea — catches taps on any empty area of the screen.
    // Placed first so it renders behind the content; foreground buttons still capture their own events.
    TouchArea {
        width: 100%;
        height: 100%;
        clicked => { root.screen-tapped(); }
    }

    // Internal toast state.
    // display-amount holds the last non-zero amount so the text stays correct
    // while the toast is fading out (avoids a "+0 ֏" flash).
    // toast-active drives y independently of last-added-amount so the rise
    // and fade-out can be decoupled.
    property <int> display-amount: 0;
    property <bool> toast-active: false;

    // Phase 1 — capture amount and start rise (~1 frame after trigger)
    Timer {
        interval: 16ms;
        running: root.last-added-amount != 0 && !root.toast-active;
        triggered => {
            root.display-amount = root.last-added-amount;
            root.toast-active = true;
        }
    }

    // Phase 2 — fade out after showing for ~1100ms
    Timer {
        interval: 1100ms;
        running: root.last-added-amount != 0;
        triggered => { root.last-added-amount = 0; }
    }

    // Phase 3 — snap y back to start while invisible (600ms > opacity fade of 500ms)
    Timer {
        interval: 600ms;
        running: root.last-added-amount == 0 && root.toast-active;
        triggered => { root.toast-active = false; }
    }
    
    VerticalLayout {
        alignment: start;
        padding: 32px;
        spacing: 32px;

        HorizontalLayout {
            alignment: start;

            if root.current-amount == 0: Button {
                text: "← Cancel";
                width: 150px;
                height: 60px;

                clicked => {
                    root.cancel-clicked();
                }
            }

            if root.current-amount > 0: Text {
                text: "🔒 Cannot cancel after inserting money";
                font-size: 16px;
                color: Palette.foreground;
                opacity: 0.5;
                vertical-alignment: center;
                height: 60px;
            }
        }

        // header
        Text {
            text: "Please Insert Money";
            font-size: 36px;
            font-weight: 700;
            color: Palette.foreground;
            horizontal-alignment: center;
        }

        Text {
            text: "Donating as @" + root.username;
            font-size: 20px;
            color: Palette.foreground;
            opacity: 0.7;
            horizontal-alignment: center;
        }

        Text {
            text: "Donating to " + root.fundname;
            font-size: 20px;
            color: Palette.foreground;
            opacity: 0.7;
            horizontal-alignment: center;
        }

        // spacer
        Rectangle {
            height: 48px;
        }

        // amount display
        VerticalLayout {
            spacing: 16px;
            alignment: center;

            Text {
                text: "Inserted Amount:";
                font-size: 24px;
                color: Palette.foreground;
                horizontal-alignment: center;
                opacity: 0.8;
            }
            
            // Wrapper for the amount box and the toast overlay.
            // clip: false so the toast can float above the box.
            Rectangle {
                height: 120px;
                clip: false;

                amount-box := Rectangle {
                    width: 100%;
                    height: 100%;
                    border-radius: 16px;
                    background: Palette.color-scheme == ColorScheme.dark ? #2a2a2a : #f5f5f5;
                    border-width: 3px;
                    border-color: root.current-amount > 0 ? #4CAF50 : #cccccc;

                    HorizontalLayout {
                        alignment: center;

                        Text {
                            text: root.current-amount + " ֏";
                            font-size: 64px;
                            font-weight: 700;
                            color: root.current-amount > 0 ? #4CAF50 : Palette.foreground;
                            horizontal-alignment: center;
                        }
                    }
                }

                // Toast: rises upward above the amount box then fades out.
                toast-text := Text {
                    text: "+" + root.display-amount + " ֏";
                    color: #4CAF50;
                    font-size: 38px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    width: parent.width;
                    // Rise from just above the box edge to well above it.
                    y: root.toast-active ? -90px : -20px;
                    // Fade in when amount is set; fade out when timer clears it.
                    opacity: root.last-added-amount != 0 ? 1.0 : 0.0;

                    animate opacity { duration: 500ms; }
                    animate y { duration: 1000ms; easing: ease-in-out; }
                }
            }
        }

        // instructions
        Text {
            text: "Insert bills or coins into me";
            font-size: 18px;
            color: Palette.foreground;
            horizontal-alignment: center;
            opacity: 0.7;
        }

        // spacer to push button to bottom
        Rectangle {
            vertical-stretch: 1;
        }

        // done button
        HorizontalLayout {
            alignment: center;

            done-button := Button {
                text: "Done ✓";
                primary: true;
                enabled: root.current-amount > 0;
                width: 350px;
                height: 120px;

                clicked => {
                    root.done-clicked(root.username, root.current-amount);
                }
            }
        }

        // status text
        if root.current-amount == 0 : Text {
            text: "Done button will be enabled after inserting money";
            font-size: 14px;
            color: Palette.foreground;
            horizontal-alignment: center;
            opacity: 0.6;
        }

        // inactivity countdown warning
        Rectangle {
            height: 40px;
            border-radius: 8px;
            background: root.seconds-left <= 30 ? #ff4444.with-alpha(0.15) :
                        root.seconds-left <= 60 ? #ff8800.with-alpha(0.12) :
                        transparent;

            Text {
                text: root.current-amount > 0
                    ? "⏱ Auto-approves in " + root.seconds-left + "s"
                    : "⏱ Auto-cancels in " + root.seconds-left + "s";
                font-size: 14px;
                color: root.seconds-left <= 30 ? #ff4444 :
                       root.seconds-left <= 60 ? #ff8800 :
                       Palette.foreground;
                opacity: root.seconds-left <= 60 ? 1.0 : 0.5;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: parent.width;
                height: parent.height;
            }
        }
    }
}
