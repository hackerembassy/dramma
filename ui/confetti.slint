import { Palette } from "std-widgets.slint";

component ConfettiPiece inherits Image {
    in property <bool> active: false;
    in property <length> start-x: 620px;
    in property <length> start-y: 960px;
    in property <length> end-x: 0px;
    in property <length> end-y: 0px;
    in property <duration> anim-delay: 0ms;
    in property <duration> anim-duration: 750ms;
    in property <brush> piece-color: #FF6B6B;

    x: active ? end-x : start-x;
    y: active ? end-y : start-y;
    colorize: piece-color;
    opacity: active ? 0.0 : 1.0;

    animate x {
        duration: anim-duration;
        delay: anim-delay;
        easing: ease-out;
    }

    animate y {
        duration: anim-duration;
        delay: anim-delay;
        easing: ease-out;
    }

    animate opacity {
        duration: anim-duration;
        delay: anim-delay;
        easing: ease-in;
    }
}

export component ConfettiOverlay inherits Rectangle {
    in property <bool> falling: false;

    background: transparent;

    // Thank-you card — centered
    Rectangle {
        x: (root.width - self.width) / 2;
        y: (root.height - self.height) / 2;
        width: 520px;
        height: 200px;
        border-radius: 24px;
        background: Palette.color-scheme == ColorScheme.dark ? #2a2a2aee : #ffffffee;
        opacity: root.falling ? 1.0 : 0.0;

        animate opacity {
            duration: 400ms;
            easing: ease-out;
        }

        VerticalLayout {
            alignment: center;

            Text {
                text: "Thank You! 🎉";
                font-size: 52px;
                font-weight: 800;
                color: Palette.foreground;
                horizontal-alignment: center;
